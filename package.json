{
  "name": "wintima-foundation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test:unit": "vitest run",
    "validate": "npm run lint && npm run format:check && npm run typecheck && npm run test:unit",
    "test:e2e": "playwright test",
    "security:audit": "npm audit --audit-level=high",
    "ci:check": "npm run validate && npm run build && npm run security:audit",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:e2e:smoke": "playwright test e2e/pages e2e/navigation.spec.ts e2e/404.spec.ts",
    "test:e2e:seo": "playwright test e2e/seo.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@next/third-parties": "15.5.18",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.513.0",
    "next": "15.5.18",
    "postcss": "^8.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.57.0",
    "react-intersection-observer": "^9.16.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.53"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/eslintrc": "^3",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lighthouse": "^13.3.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.8",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "22.x"
  }
}
